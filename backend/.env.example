DATABASE_URL=postgresql+asyncpg://osmo:osmo_dev@localhost:5432/osmo
REDIS_URL=redis://localhost:6379/0

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

FERNET_KEY=
SENTRY_DSN=

# ---------------------------------------------------------------------------
# OpenClaw integration (optional — AI-for-AI delegation)
# ---------------------------------------------------------------------------
# Set OPENCLAW_ENABLED=true to activate intelligent task delegation.
# Start the sidecar: docker compose -f docker-compose.yml -f docker-compose.openclaw.yml up -d
OPENCLAW_ENABLED=false
OPENCLAW_URL=http://localhost:18790
OPENCLAW_TOKEN=your-openclaw-gateway-token
# Generate a token: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=your-openclaw-gateway-token
